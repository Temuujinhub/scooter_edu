# ──────────────────────────────────────────────────────────────────
# ScooterEdu MN — Орчны хувьсагч (ТЕСТ DEFAULT утгууд)
# Бодит production-д эдгээрийг .env.local дотор дарж бичнэ.
# ──────────────────────────────────────────────────────────────────

# Өгөгдлийн сан (тестэд SQLite — тэг тохиргоо). Postgres руу солихдоо:
# DATABASE_URL="postgresql://user:pass@localhost:5432/scooteredu"
DATABASE_URL="file:./dev.db"

# JWT нууц түлхүүр (production-д заавал солино!)
JWT_SECRET="scooteredu-mn-test-secret-key-change-in-production-2026"

# ТЕСТ ГОРИМ — true үед:
#  • SMS OTP бодитоор илгээхгүй, дэлгэц дээр харагдана
#  • Хур (XYP) системээс мок мэдээлэл татна
#  • QPay төлбөрийг симуляци хийнэ ("Төлбөр баталгаажуулах" товч)
TEST_MODE="true"

# Платформын суурь URL (callback, verify холбоосуудад ашиглана)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Хамгийн бага зөвшөөрөгдөх нас (хуулийн шаардлага)
MIN_AGE="18"

# ── QPay тохиргоо (бодит нэгтгэлд) ───────────────────────────────
QPAY_BASE_URL="https://merchant.qpay.mn/v2"
QPAY_USERNAME="TEST_MERCHANT"
QPAY_PASSWORD="TEST_PASSWORD"
QPAY_INVOICE_CODE="SCOOTEREDU_MN_INVOICE"

# ── Хур (XYP) — Засгийн газрын мэдээлэл солилцооны систем ─────────
XYP_BASE_URL="https://xyp.gov.mn/api"
XYP_ACCESS_TOKEN="TEST_XYP_TOKEN"
XYP_WSDL_USERNAME="TEST"
XYP_WSDL_PASSWORD="TEST"

# ── SMS Gateway (Mobicom / Unitel) ───────────────────────────────
SMS_PROVIDER="mock"
SMS_API_KEY="TEST_SMS_KEY"
SMS_SENDER="ScooterEdu"

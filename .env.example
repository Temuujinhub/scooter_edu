# ScooterEdu MN — Орчны хувьсагчийн жишээ.
# Локал тестэд .env файл аль хэдийн бэлэн (тест default утгуудтай).
# Production-д энэ файлыг .env.local болгон хуулж бодит утгуудаар солино.

# PostgreSQL — Neon/Vercel Postgres холболтын мөр
DATABASE_URL="postgresql://USER:PASS@HOST/DB?sslmode=require"
JWT_SECRET="<random-32-char-secret>"
TEST_MODE="false"
NEXT_PUBLIC_APP_URL="https://scooteredu.mn"
MIN_AGE="18"

# QPay (https://merchant.qpay.mn)
QPAY_BASE_URL="https://merchant.qpay.mn/v2"
QPAY_USERNAME="<qpay-merchant-username>"
QPAY_PASSWORD="<qpay-merchant-password>"
QPAY_INVOICE_CODE="<qpay-invoice-code>"

# Хур (XYP) — https://xyp.gov.mn
XYP_BASE_URL="https://xyp.gov.mn/api"
XYP_ACCESS_TOKEN="<xyp-access-token>"
XYP_WSDL_USERNAME="<xyp-username>"
XYP_WSDL_PASSWORD="<xyp-password>"

# SMS Gateway
SMS_PROVIDER="mobicom"
SMS_API_KEY="<sms-api-key>"
SMS_SENDER="ScooterEdu"
